{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "prebuildCommand": "node ../../node_modules/typescript/bin/tsc -p ../../packages/shared/tsconfig.json"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "testflight": {
      "extends": "base",
      "distribution": "store",
      "channel": "preview",
      "ios": {
        "autoIncrement": true,
        "image": "macos-tahoe-26.4-xcode-26.4"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6785253065"
      },
      "android": {
        "serviceAccountKeyPath": "./tanren-f202fb97b00c.json",
        "track": "internal"
      }
    }
  }
}
