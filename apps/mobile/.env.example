# Copy this file to .env and fill in all values.
# NEVER commit .env — it is gitignored.

# API URL — local: http://localhost:3000, prod: https://api.yourapp.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# Dev bypass — seeded dev user UUID (dev builds only)
EXPO_PUBLIC_DEV_USER_ID=

# Google Sign-In — leave blank to hide the Google button entirely
# iOS client ID: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 → iOS type
# Web client ID: same console → Web application type
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
