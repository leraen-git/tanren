{
  "expo": {
    "name": "Tanren",
    "slug": "tanren",
    "version": "1.0.2",
    "scheme": "tanren",
    "orientation": "portrait",
    "icon": "./assets/icon/tanren_icon_1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/Tanren.icon",
      "bundleIdentifier": "app.tanren",
      "infoPlist": {
        "UIUserInterfaceStyle": "Automatic",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.499901737559-nqbmbv9djsi4c88eh08h8hqv0ofadesr"
            ]
          }
        ],
        "NSPhotoLibraryUsageDescription": "Tanren needs access to your photo library to add a background photo to your session share card.",
        "NSCameraUsageDescription": "Tanren needs access to your camera to take a photo for your session share card.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/tanren_adaptive_foreground.png",
        "backgroundImage": "./assets/icon/tanren_adaptive_background.png",
        "monochromeImage": "./assets/icon/tanren_adaptive_monochrome.png"
      },
      "package": "app.tanren",
      "versionCode": 4,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/933ef993-9092-4e5c-aaa8-af38a9735b8d"
    },
    "plugins": [
      "./plugins/withFixSpacesInPath",
      "./plugins/withFmtCpp17Fix",
      "./plugins/withModularHeaders",
      "./plugins/withSingleTaskLaunchMode",
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "../../node_modules/@expo-google-fonts/barlow-condensed/300Light/BarlowCondensed_300Light.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/400Regular/BarlowCondensed_400Regular.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/500Medium/BarlowCondensed_500Medium.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/700Bold/BarlowCondensed_700Bold.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/900Black/BarlowCondensed_900Black.ttf",
            "./assets/fonts/NotoSerifJP_700Bold_subset.ttf",
            "./assets/fonts/NotoSerifJP_900Black_subset.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8192C"
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-web-browser",
      "expo-secure-store",
      "expo-audio",
      "expo-asset",
      "expo-localization",
      "expo-sharing",
      "expo-image",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "933ef993-9092-4e5c-aaa8-af38a9735b8d"
      }
    },
    "owner": "leraen"
  }
}
