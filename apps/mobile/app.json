{
  "expo": {
    "name": "Tanren",
    "slug": "tanren",
    "version": "1.0.0",
    "entryPoint": "../../node_modules/expo-router/entry",
    "scheme": "tanren",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF",
      "dark": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.tanren",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.YOUR_IOS_CLIENT_ID"
            ]
          }
        ],
        "NSPhotoLibraryUsageDescription": "Tanren needs access to your photo library to add a background photo to your session share card.",
        "NSCameraUsageDescription": "Tanren needs access to your camera to take a photo for your session share card."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "app.tanren"
    },
    "plugins": [
      "./plugins/withFixSpacesInPath",
      "./plugins/withFmtCpp17Fix",
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "../../node_modules/@expo-google-fonts/barlow-condensed/300Light/BarlowCondensed_300Light.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/400Regular/BarlowCondensed_400Regular.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/500Medium/BarlowCondensed_500Medium.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/700Bold/BarlowCondensed_700Bold.ttf",
            "../../node_modules/@expo-google-fonts/barlow-condensed/900Black/BarlowCondensed_900Black.ttf",
            "./assets/fonts/NotoSerifJP_700Bold_subset.ttf",
            "./assets/fonts/NotoSerifJP_900Black_subset.ttf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8192C"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-audio",
      "expo-asset",
      "expo-localization",
      "expo-sharing",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
