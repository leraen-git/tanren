# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env — it is gitignored.

NODE_ENV=development

# Postgres — local: postgresql://localhost/tanren, prod: your connection string
DATABASE_URL=postgresql://localhost/tanren

# Redis — local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Server port
PORT=3000

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -base64 64
# The API signs session tokens with this secret; the mobile app includes them
# in every request as Authorization: Bearer <token>
JWT_SECRET=change-me-in-production

# Dev-only fallback: when no token is provided and NODE_ENV=development,
# use this internal user UUID as the authenticated user.
# Run db:seed first — it creates a user with this ID.
DEV_USER_ID=dev_user
# Must also be set to 'true' to enable the fallback — extra guard so that
# NODE_ENV=development leaking into prod never activates auth bypass
ENABLE_DEV_AUTH=true

# ── Anthropic (https://console.anthropic.com) ────────────────────────────────
# Required for AI plan and diet generation.
ANTHROPIC_API_KEY=sk-ant-...

# ── Email OTP (https://resend.com) ───────────────────────────────────────────
# Leave blank in development — OTP codes are printed to the server console.
# Required in production for email sign-in.
RESEND_API_KEY=re_...
# Sender address (must be a verified Resend domain — uses send.tanren.fr subdomain)
FROM_EMAIL=Tanren <noreply@send.tanren.fr>
# Reply-to address (goes to iCloud+ mailbox on root tanren.fr)
REPLY_TO_EMAIL=support@tanren.fr

# ── Encryption at rest ───────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -base64 32
# Used for AES-256-GCM encryption of PII (email, name, diet fields).
# If unset in dev, encryption is skipped with a warning.
ENCRYPTION_KEY=

# ── Database pool tuning ─────────────────────────────────────────────────
# Optional: tune pg connection pool (defaults shown)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000

# ── Production only ──────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (e.g. https://tanren.fr)
ALLOWED_ORIGINS=
