# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env — it is gitignored.

NODE_ENV=development

# Postgres — local: postgresql://localhost/fittrack, prod: your connection string
DATABASE_URL=postgresql://localhost/fittrack

# Redis — local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Server port
PORT=3000

# ── Clerk (https://dashboard.clerk.com) ─────────────────────────────────────
# Required in production. In dev you can leave blank and use DEV_CLERK_ID below.
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Dev-only fallback user when CLERK_SECRET_KEY is blank (never set in production)
DEV_CLERK_ID=dev_user
# Must also be set to 'true' to enable the DEV_CLERK_ID fallback — double guard
# so that NODE_ENV=development leaking into prod never activates auth bypass
ENABLE_DEV_AUTH=true

# ── Anthropic (https://console.anthropic.com) ────────────────────────────────
# Required for AI plan and diet generation.
ANTHROPIC_API_KEY=sk-ant-...

# ── Production only ──────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (e.g. https://fittrack.app)
ALLOWED_ORIGINS=
