{
  "name": "@fittrack/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/types.ts",
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "db:seed-history": "tsx --env-file=.env src/db/seed-history.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fittrack/shared": "*",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.3",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "resend": "^6.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
