{
  "name": "tanren",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package && node scripts/patch-rn-space-paths.js",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "ajv": "^8.17.1",
    "react-native-worklets": "0.7.4"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@expo-google-fonts/noto-serif-jp": "^0.4.3",
    "expo": "^55.0.17",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "~4.2.1",
    "react-native-svg": "15.15.3"
  },
  "version": "1.0.0"
}
